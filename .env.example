# FDAC (Fitness Data Analytics Course) — environment template
#
# Copy this file to `.env.local` and fill in real values. `.env*` is gitignored
# except this file. Production values live in Vercel → Settings → Environment
# Variables. Preview deploys must not have live outbound webhooks wired — rely
# on the dev-log fallback in lib/inbox.ts and lib/recaptcha.ts.
#
# Provisioning checklist: plans/21-fdac-ecs-rebuild-secret-provisioning.md §A–§D
# (Keap rows there are stale — Keap is on the backlog as of 2026-05-04).

# --- Database (Neon Postgres) ---------------------------------------------
# Pooled URL — used at request time by lib/db.ts via @neondatabase/serverless
STORAGE_DATABASE_URL=
# Unpooled URL — used by drizzle-kit for migrations (db:push, db:studio)
STORAGE_DATABASE_URL_UNPOOLED=

# --- Google reCAPTCHA v3 --------------------------------------------------
# Public site key — exposed to the browser (safe to commit in a real env file)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# Secret key — server-side verification only. NEVER expose to the client.
RECAPTCHA_SECRET_KEY=

# --- Signed inbox webhook (witus-inbox) -----------------------------------
# Production: https://inbox.witus.online/api/ingest
# Local:      http://localhost:3001/api/ingest   (witus-inbox dev runs on :3001;
#                                                 FDAC dev runs on :3000)
INBOX_INGEST_URL=
# Per-source HMAC seed — must match the witus-inbox INGEST_SOURCES["fdac"] entry
# (≥ 32 chars; generate via `openssl rand -hex 32`)
INBOX_INGEST_SECRET=
# Source slug — pinned; do not change without updating witus-inbox INGEST_SOURCES
INBOX_SOURCE_SLUG=fdac

# --- Ebook signed-URL JWT -------------------------------------------------
# Signs 24h-expiry JWTs for /ebook/[slug]?t=<jwt> downloads.
# (≥ 32 chars; generate via `openssl rand -hex 32`)
EBOOK_JWT_SECRET=
# Absolute base URL used to construct download links.
# Production: https://fdac.witus.online
# Preview:    leave blank — lib/env.ts derives from VERCEL_URL at request time
# Local:      http://localhost:3000
EBOOK_BASE_URL=

# --- Local-dev escape hatch ----------------------------------------------
# Uncomment during early rebuild to skip validate-env.ts checks at build time.
# Remove before any production-bound build.
# SKIP_ENV_VALIDATION=true
