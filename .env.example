# FDAC (Fitness Data Analytics Course) — environment template
#
# Copy this file to `.env.local` and fill in real values. `.env*` is gitignored
# except this file. Production values live in Vercel → Settings → Environment
# Variables. Preview deploys must not have live outbound webhooks wired — rely
# on the "degrade to dev-log" fallback (see plans/00-descriptions.md §3 Security).

# --- Database --------------------------------------------------------------
# MongoDB Atlas connection string for the waitlist + verification-token
# collections. Dedicated cluster for this repo — do not share across products.
MONGODB_URI=

# --- Auth (next-auth v4) ---------------------------------------------------
# Secret used to sign next-auth session + CSRF tokens. Generate with:
#   openssl rand -base64 32
AUTH_SECRET=

# --- reCAPTCHA v3 ----------------------------------------------------------
# Public site key — exposed to the browser; safe to commit in a real deploy env
# but still lives here so preview deploys don't break. Domain allowlist is
# managed in the reCAPTCHA admin console.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# Secret key — server-side verification only. NEVER expose to the client.
RECAPTCHA_SECRET_KEY=

# --- Pabbly workflow -------------------------------------------------------
# Webhook URL that receives the waitlist payload on submit. Pabbly handles
# downstream routing (confirmation email, Keap fallback, ops notifications).
# Leave blank in preview deploys — the Pabbly client must degrade to dev-log.
PABBLY_ORDER_WEBHOOK=

# --- Keap (Infusionsoft) ---------------------------------------------------
# App id + API credentials for pushing leads into the CRM.
KEAP_APP_ID=
KEAP_API_KEY_CLIENT_ID=
KEAP_API_KEY_SECRET=

# Public Keap form metadata — used by the client-side form component to tag
# submissions with the correct Keap form id + name.
NEXT_PUBLIC_KEAP_FORM_ID=
NEXT_PUBLIC_KEAP_FORM_NAME=

# --- Ecosystem inbox (v1b, not wired yet) ----------------------------------
# HMAC seed for signing the POST /api/ingest call into witus-inbox. Populate
# once the v1b inbox-ingest plan is scheduled. See
# plans/ecosystem/fitness-data-analytics-course-landing-page.md §Roadmap v1b.
# INBOX_INGEST_URL=
# INBOX_INGEST_HMAC_SEED=
# INBOX_SOURCE_SLUG=fdac
